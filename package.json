    "lint:fix": "oxlint --fix",
    "prepack": "nuxt-module-build build",
    "test": "bunx nuxi prepare playground && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nuxt/kit": "^4.2.2",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.1",
    "@nuxt/test-utils": "^3.19.2",
    "@nuxtjs/i18n": "^10.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.5.2",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.6.3",
    "nuxt": "^4.2.2",
    "oxfmt": "^0.18.0",
    "oxlint": "^1.17.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vue": "^3.5.18",
    "vue-component-type-helpers": "^3.2.2",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "nuxt": "^3.17.0 || ^4.0.0",
