{
  "name": "@henry753951/nuxt-imperative-modals",
  "version": "0.1.1",
  "description": "Imperative modal orchestration for Nuxt with generated modal prop and emit types.",
  "homepage": "https://github.com/henry753951/nuxt-imperative-modals#readme",
  "bugs": {
    "url": "https://github.com/henry753951/nuxt-imperative-modals/issues"
  },
